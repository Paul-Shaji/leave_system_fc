 "html": "<div style=\"font-family: Arial, sans-serif; padding: 20px;\">\r\n\r\n    <div style=\"text-align: center; margin-bottom: 30px;\">\r\n        <h2 style=\"margin: 0; color: #1e293b;\">Leave Application</h2>\r\n        <p style=\"color: #64748b; margin: 4px 0;\">{{ doc.name }}</p>\r\n    </div>\r\n\r\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; width: 40%; background: #f8fafc; font-weight: bold;\">\r\n                Employee Name\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.employee_name }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Employee ID\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.employee_id or \"\u2014\" }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Department\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.department or \"\u2014\" }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Leave Type\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.leave_type }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                From\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.from_date }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                To \r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.to_date }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Number of Days\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.number_of_days }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Status\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                <span style=\"\r\n                    padding: 4px 12px;\r\n                    border-radius: 12px;\r\n                    font-size: 12px;\r\n                    font-weight: bold;\r\n                    background: {% if doc.status == 'Approved' %}#dcfce7{% elif doc.status == 'Rejected' %}#fee2e2{% else %}#dbeafe{% endif %};\r\n                    color: {% if doc.status == 'Approved' %}#15803d{% elif doc.status == 'Rejected' %}#dc2626{% else %}#1d4ed8{% endif %};\r\n                \">\r\n                    {{ doc.status }}\r\n                </span>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Applied On\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.applied_on }}\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: bold;\">\r\n                Reason\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0;\">\r\n                {{ doc.reason }}\r\n            </td>\r\n        </tr>\r\n        {% if doc.rejection_reason %}\r\n        <tr>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; background: #fef2f2; font-weight: bold; color: #dc2626;\">\r\n                Rejection Reason\r\n            </td>\r\n            <td style=\"padding: 10px; border: 1px solid #e2e8f0; color: #dc2626;\">\r\n                {{ doc.rejection_reason }}\r\n            </td>\r\n        </tr>\r\n        {% endif %}\r\n    </table>\r\n\r\n    <div style=\"margin-top: 60px; display: flex; justify-content: space-between;\">\r\n        <div style=\"text-align: center;\">\r\n            <div style=\"border-top: 1px solid #1e293b; width: 200px; padding-top: 8px;\">\r\n                Employee Signature\r\n            </div>\r\n        </div>\r\n        <div style=\"text-align: center;\">\r\n            <div style=\"border-top: 1px solid #1e293b; width: 200px; padding-top: 8px;\">\r\n                Manager Signature\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n</div>",
